# Database credentials — REQUIRED, no default. Generate your own, do not reuse this file's values.
DB_PASSWORD=replace-with-a-strong-unique-password
DB_ROOT_PASSWORD=replace-with-a-different-strong-unique-password

# JWT secret — REQUIRED, no default. Generate a long random string (min 32 chars), e.g.:
#   openssl rand -base64 48
JWT_SECRET=replace-with-output-of-openssl-rand--base64-48

# ── GitHub Actions secrets ────────────────────────────────────────────────────
# Set these in: GitHub repo → Settings → Secrets & Variables → Actions
#
# DO_DROPLET_IP=        Droplet public IP address
# DO_DROPLET_USER=      SSH user (usually "root")
# DO_DROPLET_PASSWORD=  SSH password for the droplet
